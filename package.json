{
  "name": "associative-questionnaire",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20 <21"
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "check": "tsc --noEmit --project tsconfig.json",
    "generate": "node --import tsx src/cli/generate-survey-html.ts",
    "install:ssh": "node --import tsx src/cli/install-vps-over-ssh.ts",
    "manual:container": "bash scripts/manual-container.sh",
    "manual:save": "node --import tsx src/cli/manual-save-survey.ts",
    "prepare:container": "node --import tsx src/cli/prepare-container-assets.ts",
    "prepare:visual": "node --import tsx src/cli/prepare-visual-showcase.ts",
    "test": "vitest run",
    "test:container": "bash scripts/test-container.sh",
    "test:integration": "bash scripts/test-integration.sh",
    "test:ssh-deployment": "bash scripts/test-ssh-deployment.sh",
    "test:visual": "bash scripts/test-visual.sh",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@amiceli/vitest-cucumber": "^6.3.0",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^24.0.0",
    "jsdom": "^26.1.0",
    "tsx": "^4.20.6",
    "typescript": "^5.8.0",
    "vitest": "^4.0.4",
    "yaml": "^2.8.1"
  },
  "dependencies": {
    "handlebars": "^4.7.8",
    "zod": "^3.24.2"
  }
}
